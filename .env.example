# ═══════════════════════════════════════════════════
#  Discord Voice Camper + Custom RPC — .env config
# ═══════════════════════════════════════════════════

# ── Require ────────────────────────────────────────
TOKEN=your_discord_token_here
VOICE_CHANNEL_ID=123456789012345678
GUILD_ID=123456789012345678

# ── Status ──────────────────────────────────────────
# online | idle | dnd | invisible
STATUS=idle

# ── RPC — Simple ────────────────────────────────────
# RPC_TYPE:
#   0 = Playing
#   1 = Streaming  (need RPC_STREAM_URL)
#   2 = Listening to
#   3 = Watching
#   5 = Competing in
RPC_TYPE=3
RPC_NAME=something cool
RPC_DETAILS=optional details line
RPC_STATE=optional state line

# ── RPC — Image ───────────────────────────────────────
# APPLICATION_ID: taken from https://discord.com/developers/applications
# It is necessary to use the asset key as a large/small image.
# If using link https:// then it's not needed APPLICATION_ID=

# RPC_LARGE_IMAGE / RPC_SMALL_IMAGE:
#   There are two ways to use it:
#   1. Asset key  → upload images to the Discord app → use the asset name. (need APPLICATION_ID)
#   2. external URL  → start with https://
RPC_LARGE_IMAGE=https://i.imgur.com/example.png
RPC_LARGE_TEXT=hover text for large images
RPC_SMALL_IMAGE=https://i.imgur.com/example2.png
RPC_SMALL_TEXT=hover text for thumbnails

# ── RPC — Timestamp ──────────────────────────────────
# RPC_SHOW_ELAPSED=YES  → show "xx:xx elapsed" (from the moment of startup)
# RPC_END_TIMESTAMP     → unix timestamp end (vd: 1700000000), leave blank = not in use
RPC_SHOW_ELAPSED=YES
RPC_END_TIMESTAMP=

# ── RPC — Buttons (max: 2) ────────────────────────
# URL need to start with https://
RPC_BUTTON1_LABEL=Visit Website
RPC_BUTTON1_URL=https://example.com
RPC_BUTTON2_LABEL=
RPC_BUTTON2_URL=

# ── Bot ─────────────────────────────────────────────
PREFIX=.

# ── Render (optional) ────────────────────────────────
# PORT=10000
